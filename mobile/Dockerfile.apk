FROM reactnativecommunity/react-native-android:latest

WORKDIR /app

# Install Node dependencies
COPY package*.json ./
RUN npm install

# Copy project files
COPY . .

# Generate native Android project from Expo config
RUN npx expo prebuild --platform android --no-install --clean

# Build APK and copy to mounted output directory
CMD cd android && \
    chmod +x gradlew && \
    ./gradlew assembleRelease --no-daemon && \
    mkdir -p /output && \
    cp app/build/outputs/apk/release/app-release.apk /output/app.apk && \
    echo "✓ APK gotowy: /output/app.apk"
